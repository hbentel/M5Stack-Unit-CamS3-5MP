#pragma once

#include "esp_err.h"

/**
 * Validate OPI PSRAM is detected and usable.
 * Returns ESP_OK if PSRAM is initialized and reports expected size.
 */
esp_err_t hw_validate_psram(void);

/**
 * Scan the I2C bus and verify the PY260 sensor is present.
 * Configures I2C master at 400kHz on the board's I2C pins,
 * probes for device at address 0x1F.
 * Returns ESP_OK if sensor responds to probe.
 */
esp_err_t hw_validate_i2c_sensor(void);
